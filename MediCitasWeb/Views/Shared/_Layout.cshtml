<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - MediCitas</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        /* Animación del punto del asistente */
        .pulse-dot {
            width: 8px;
            height: 8px;
            background-color: #28a745;
            border-radius: 50%;
            display: inline-block;
            margin-right: 5px;
            box-shadow: 0 0 0 rgba(40, 167, 69, 0.4);
            animation: pulse 2s infinite;
        }

        @@keyframes pulse {
            0% {
                box-shadow: 0 0 0 0 rgba(40, 167, 69, 0.4);
            }

            70% {
                box-shadow: 0 0 0 10px rgba(40, 167, 69, 0);
            }

            100% {
                box-shadow: 0 0 0 0 rgba(40, 167, 69, 0);
            }
        }

        /* Ajuste para el botón del asistente en el nav */
        .btn-asistente-nav {
            background-color: rgba(255, 255, 255, 0.15);
            color: white !important;
            border: 1px solid rgba(255, 255, 255, 0.3);
            transition: all 0.3s ease;
        }

            .btn-asistente-nav:hover {
                background-color: white;
                color: var(--bs-primary) !important;
            }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm" id="navApp">
        <div class="container">
            <a class="navbar-brand fw-bold" href="@Url.Action("Dashboard", "Home")">
                <i class="bi bi-heart-pulse-fill"></i> MEDICITAS
            </a>

            <div class="d-flex align-items-center gap-3">
                <a href="@Url.Action("ChatBot", "Chat")" class="btn btn-sm btn-asistente-nav rounded-pill px-3 d-flex align-items-center">
                    <span class="pulse-dot"></span>
                    <i class="bi bi-robot me-1"></i>
                    <span class="d-none d-sm-inline">Asistente</span>
                </a>

                <div class="text-white border-start ps-3 d-flex align-items-center">
                    <span class="small me-3 d-none d-md-inline">@Session["usuario"]</span>
                    <a href="@Url.Action("Login", "Auth")" class="btn btn-sm btn-light text-danger fw-bold rounded-pill">
                        <i class="bi bi-box-arrow-right"></i> Salir
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <main class="container py-4">
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/vue@3.4.21/dist/vue.global.prod.js"></script>

    @RenderSection("scripts", required: false)
</body>
</html>