@model List<MediCitasWeb.Models.CitaPacienteViewModel>
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Panel Doctor - MediCitas</title>
    <link href="~/Content/doctor.css" rel="stylesheet" />
</head>

<body class="doctor-page">

    <header class="doctor-header">
        <div>
            <h2>Panel del Doctor</h2>
            <span class="especialidad">
                Dr. @ViewBag.NombreDoctor
            </span>
        </div>

        <div class="header-actions">
            <span class="contador" id="contadorCitas">
                Citas totales: @Model.Count
            </span>
            <a href="@Url.Action("Logout", "Admin")" class="btn-logout">Cerrar sesión</a>
        </div>
    </header>

    <main class="contenido-citas">
        <div class="filtros">
            <input type="text" id="buscador" placeholder="Buscar por documento..." />
            <input type="date" id="filtroFecha" />
            <button type="button" onclick="limpiarFiltros()">Limpiar</button>
        </div>

        <table class="tabla-citas">
            <thead>
                <tr>
                    <th>Paciente</th>
                    <th>Documento</th>
                    <th>Fecha</th>
                    <th>Hora</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr class="fila-cita">
                        <td>@item.NombrePaciente</td>
                        <td class="doc">@item.Documento</td>
                        <td class="fecha">@item.Fecha.ToString("yyyy-MM-dd")</td>
                        <td>@item.Hora.ToString(@"hh\:mm")</td>
                        <td>
                            <span class="estado badge @item.Estado.ToLower()">@item.Estado</span>
                        </td>
                        <td>
                            <button type="button" class="btn-ver" onclick="toggleDetalle(this)">
                                Detalles
                            </button>
                        </td>
                    </tr>
                    <tr class="detalle-row" style="display:none;">
                        <td colspan="6">
                            <div class="info-extra">
                                <p><strong>Tipo:</strong> @item.Tipo</p>
                                <p><strong>Especialidad:</strong> @item.Especialidad</p>
                                <button type="button" class="btn-completar">Marcar como Atendido</button>
                                <button type="button" class="btn-cancelar">Cancelar Cita</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </main>

    <script src="~/Scripts/app/doctor-panel.js"></script>
</body>
</html>
