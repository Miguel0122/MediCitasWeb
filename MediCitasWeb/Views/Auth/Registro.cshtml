@model MediCitasWeb.Models.RegistroViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Registro - MediCitas</title>
    <link href="~/Content/auth.css" rel="stylesheet" />
</head>

<body class="auth-page">

    <form method="post" action="@Url.Action("Registro", "Auth")">
        @Html.AntiForgeryToken()
        @Html.ValidationSummary(true, "", new { @class = "error" })

        <div class="auth-container">
            <h1>MediCitas</h1>
            <p class="subtitle">Registro de usuario</p>

            <div id="paso1">
                <label>Nombres</label>
                <input type="text" id="nombre" name="nombres" required placeholder="Escriba sus nombres" />
                <span id="errorNombre" class="error"></span>
            </div>

            <div id="paso2" style="display:none;">
                <label>Apellidos</label>
                <input type="text" id="apellidos" name="apellidos" required placeholder="Escriba sus apellidos" />
                <span id="errorApellidos" class="error"></span>
            </div>

            <div id="paso3" style="display:none;">
                <label>Número de documento</label>
                <input type="text" id="numDoc" name="numero_documento" required placeholder="Cédula o TI" />
                <span id="errorDoc" class="error"></span>
            </div>

            <div id="paso4" style="display:none;">
                <label>Correo electrónico</label>
                <input type="email" id="correo" name="correo" required placeholder="ejemplo@correo.com" />
                <span id="errorCorreo" class="error"></span>
            </div>

            <div id="paso5" style="display:none;">
                <label>Contraseña</label>
                <input type="password" id="password" name="password" required placeholder="Mínimo 6 caracteres" />
                <span id="errorPassword" class="error"></span>
            </div>

            <div id="pasoFinal" style="display:none; margin-top: 20px;">
                <button type="submit">Crear Cuenta</button>
            </div>

            <div class="auth-footer" style="margin-top: 15px; text-align: center;">
                <a href="@Url.Action("Login", "Auth")" style="color: #666; font-size: 0.9em;">¿Ya tienes cuenta? Inicia sesión</a>
            </div>
        </div>
    </form>

    <script src="~/Scripts/app/auth-registro.js"></script>
</body>
</html>