@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Recuperar contraseña</title>

    <!-- Bootstrap para estilos -->
    <link href="~/Content/bootstrap.min.css" rel="stylesheet" />
</head>
<body>
    <!-- ===================================================== -->
    <!-- BOTÓN VOLVER A INICIO DE SESIÓN (ESQUINA SUPERIOR) -->
    <!-- ===================================================== -->
    <div style="position:absolute; top:20px; right:30px;">

        <!-- Botón que redirige al Login -->
        <a href="@Url.Action("Login", "Auth")"
           class="btn btn-outline-secondary btn-sm">
            Volver a Iniciar Sesión
        </a>

    </div>

    <div class="container mt-5" style="max-width:600px;">


        <!-- TÍTULO -->
        <h4 class="text-center mb-4 fw-bold">
            RECUPERAR CONTRASEÑA
        </h4>

        <!-- ===================================================== -->
        <!-- ====================== PASO 1 ======================= -->
        <!-- ===================================================== -->
        <!-- Usuario ingresa su correo -->
        <div id="paso1">
            <label>Correo electrónico</label>
            <input type="email" id="txtCorreo" class="form-control" />

            <div class="d-grid mt-3">
                <button class="btn btn-primary" onclick="enviarCodigo()">
                    Enviar código
                </button>
            </div>
        </div>

        <!-- ===================================================== -->
        <!-- ====================== PASO 2 ======================= -->
        <!-- ===================================================== -->
        <!-- Ingresar código de verificación -->
        <div id="paso2" style="display:none;">
            <hr />
            <label>Código de verificación</label>
            <input type="text" id="txtCodigo" class="form-control" />

            <div class="d-grid mt-3">
                <button class="btn btn-success" onclick="validarCodigo()">
                    Validar código
                </button>
            </div>
        </div>

        <!-- ===================================================== -->
        <!-- ====================== PASO 3 ======================= -->
        <!-- ===================================================== -->
        <!-- Cambiar contraseña -->
        <div id="paso3" style="display:none;">
            <hr />

            <label>Nueva contraseña</label>
            <input type="password" id="txtNueva" class="form-control" />

            <label class="mt-3">Confirmar contraseña</label>
            <input type="password" id="txtConfirmar" class="form-control" />

            <div class="d-grid mt-3">
                <button class="btn btn-danger" onclick="cambiarPassword()">
                    Cambiar contraseña
                </button>
            </div>

            <script>
    // Función que redirige al login
    function volverLogin() {
        window.location.href = '@Url.Action("Login", "Auth")';
    }
            </script>
        </div>

        <!-- MENSAJES DE ESTADO -->
        <div id="mensaje" class="mt-4 text-center fw-bold"></div>

    </div>

    <script>

        // ------------------------------------------------------------
        // FUNCIÓN PARA MOSTRAR MENSAJES EN PANTALLA
        // ------------------------------------------------------------
        function mostrarMensaje(texto, tipo) {
            document.getElementById("mensaje").innerHTML =
                "<span class='text-" + tipo + "'>" + texto + "</span>";
        }


        // ------------------------------------------------------------
        // PASO 1: ENVIAR CÓDIGO
        // ------------------------------------------------------------
        function enviarCodigo() {

            // Obtener valor del correo
            let correo = document.getElementById("txtCorreo").value;

            // Validación básica
            if (correo === "") {
                mostrarMensaje("Ingrese un correo.", "danger");
                return;
            }

            // Enviar datos al controlador usando fetch
            fetch("/Auth/EnviarCodigo", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ correo: correo })
            })
                .then(r => r.json())
                .then(data => {

                    if (data.ok) {

                        // Mostrar siguiente paso
                        document.getElementById("paso2").style.display = "block";

                        mostrarMensaje("Código enviado correctamente.", "success");

                    } else {
                        mostrarMensaje(data.mensaje, "danger");
                    }

                });
        }


        // ------------------------------------------------------------
        // PASO 2: VALIDAR CÓDIGO
        // ------------------------------------------------------------
        function validarCodigo() {

            let codigo = document.getElementById("txtCodigo").value;

            fetch("/Auth/ValidarCodigo", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ codigo: codigo })
            })
                .then(r => r.json())
                .then(data => {

                    if (data.ok) {

                        // Mostrar bloque de cambio de contraseña
                        document.getElementById("paso3").style.display = "block";

                        mostrarMensaje("Código correcto.", "success");

                    } else {
                        mostrarMensaje(data.mensaje, "danger");
                    }

                });
        }


        // ------------------------------------------------------------
        // PASO 3: CAMBIAR CONTRASEÑA
        // ------------------------------------------------------------
        function cambiarPassword() {

            let nueva = document.getElementById("txtNueva").value;
            let confirmar = document.getElementById("txtConfirmar").value;

            // Validar longitud mínima
            if (nueva.length < 6) {
                mostrarMensaje("La contraseña debe tener mínimo 6 caracteres.", "danger");
                return;
            }

            // Validar que coincidan
            if (nueva !== confirmar) {
                mostrarMensaje("Las contraseñas no coinciden.", "danger");
                return;
            }

            fetch("/Auth/CambiarPassword", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ nueva: nueva })
            })
                .then(r => r.json())
                .then(data => {

                    if (data.ok) {
                        mostrarMensaje("Contraseña actualizada correctamente.", "primary");
                    } else {
                        mostrarMensaje(data.mensaje, "danger");
                    }

                });
        }

    </script>

</body>
</html>