@{
    ViewBag.Title = "Recuperar contraseña";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Recuperar contraseña</title>

    <link href="~/Content/bootstrap.min.css" rel="stylesheet" />
    <link href="~/Content/user.css" rel="stylesheet" />
</head>
<body>

    <div class="container mt-5 user-container" style="max-width: 600px;">

        <h4 class="fw-bold mb-4 text-center">
            RECUPERAR CONTRASEÑA
        </h4>

        <!-- PASO 1 -->
        <div class="mb-3">
            <label class="form-label">Correo electrónico</label>
            <input type="email" id="txtCorreo" class="form-control"
                   placeholder="Ingrese su correo registrado" />
        </div>

        <div class="d-grid mb-4">
            <button class="btn btn-primary" onclick="enviarCodigo()">
                Enviar código
            </button>
        </div>

        <!-- PASO 2 (OCULTO) -->
        <div id="bloqueCodigo" style="display:none;">

            <hr />

            <div class="mb-3">
                <label class="form-label">Ingrese el código enviado</label>
                <input type="text" id="txtCodigo" class="form-control"
                       placeholder="Código de verificación" />
            </div>

            <div class="d-grid mb-4">
                <button class="btn btn-success" onclick="validarCodigo()">
                    Validar código
                </button>
            </div>

        </div>

        <!-- PASO 3 (OCULTO) -->
        <div id="bloquePassword" style="display:none;">

            <hr />

            <div class="mb-3">
                <label class="form-label">Nueva contraseña</label>
                <input type="password" id="txtNueva" class="form-control"
                       placeholder="Ingrese nueva contraseña" />
            </div>

            <div class="mb-3">
                <label class="form-label">Confirmar contraseña</label>
                <input type="password" id="txtConfirmar" class="form-control"
                       placeholder="Confirme la contraseña" />
            </div>

            <div class="d-grid">
                <button class="btn btn-danger" onclick="cambiarPassword()">
                    Cambiar contraseña
                </button>
            </div>

        </div>

        <!-- MENSAJES -->
        <div id="mensaje" class="mt-4 text-center fw-bold"></div>

        <div class="text-center mt-4">
            <a href="@Url.Action("Login","Pages")" class="text-decoration-none">
                Volver al inicio de sesión
            </a>
        </div>

    </div>

    <script>
        function enviarCodigo() {
            document.getElementById("bloqueCodigo").style.display = "block";
            document.getElementById("mensaje").innerHTML =
                "<span class='text-success'>Código enviado correctamente.</span>";
        }

        function validarCodigo() {
            document.getElementById("bloquePassword").style.display = "block";
            document.getElementById("mensaje").innerHTML =
                "<span class='text-success'>Código validado.</span>";
        }

        function cambiarPassword() {
            document.getElementById("mensaje").innerHTML =
                "<span class='text-primary'>Contraseña actualizada correctamente.</span>";
        }
    </script>

</body>
</html>
