@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Recuperar contraseña</title>

    <!-- Bootstrap para estilos -->
    <link href="~/Content/bootstrap.min.css" rel="stylesheet" />
</head>
<body>

    <div id="recuperarApp">

        <div style="position:absolute; top:20px; right:30px;">
            <a href="@Url.Action("Login", "Auth")"
               class="btn btn-outline-secondary btn-sm">
                Volver a Iniciar Sesión
            </a>
        </div>

        <div class="container mt-5" style="max-width:600px;">

            <h4 class="text-center mb-4 fw-bold">
                RECUPERAR CONTRASEÑA
            </h4>

            <!-- ================= PASO 1 ================= -->
            <div v-if="step === 1">
                <label>Correo electrónico</label>
                <input type="email"
                       class="form-control"
                       v-model="correo">

                <div class="d-grid mt-3">
                    <button class="btn btn-primary"
                            @@click="enviarCodigo"
                            :disabled="loading">

                        <span v-if="loading">Enviando...</span>
                        <span v-else>Enviar código</span>

                    </button>
                </div>
            </div>

            <!-- ================= PASO 2 ================= -->
            <div v-if="step === 2">
                <hr />
                <label>Código de verificación</label>

                <input type="text"
                       class="form-control"
                       v-model="codigo">

                <div class="d-grid mt-3">
                    <button class="btn btn-success"
                            @@click="validarCodigo"
                            :disabled="loading">

                        Validar código
                    </button>
                </div>
            </div>

            <!-- ================= PASO 3 ================= -->
            <div v-if="step === 3">
                <hr />

                <label>Nueva contraseña</label>
                <input type="password"
                       class="form-control"
                       v-model="nueva">

                <label class="mt-3">Confirmar contraseña</label>
                <input type="password"
                       class="form-control"
                       v-model="confirmar">

                <div class="d-grid mt-3">
                    <button class="btn btn-danger"
                            @@click="cambiarPassword"
                            :disabled="loading">

                        Cambiar contraseña
                    </button>
                </div>
            </div>

            <!-- MENSAJES -->
            <div class="mt-4 text-center fw-bold">
                <span v-if="mensaje"
                      :class="'text-' + tipoMensaje">
                    {{ mensaje }}
                </span>
            </div>

        </div>

    </div>

    <script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>
    <script src="~/Scripts/app/recuperar-app.js"></script>

</body>
</html>