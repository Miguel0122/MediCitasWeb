@model MediCitasWeb.Models.LoginViewModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Iniciar Sesión - MediCitas</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    <link href="~/Content/auth.css" rel="stylesheet" />
</head>
<body class="auth-page">

    <div id="loginApp" class="auth-container">
        <h1>MediCitas</h1>
        <p class="subtitle">Acceso al sistema</p>

        @Html.ValidationSummary(true, "", new { @class = "validation-summary" })

    <form @@submit="handleLogin" method="post" action="@Url.Action("Login", "Auth")" id="realForm">
        @Html.AntiForgeryToken()
        <label>Número de documento</label>
        <input type="text"
               name="numero_documento"
               v-model="form.numero_documento"
               @@input="soloNumeros"
               required
               placeholder="Ingrese su identificación" />

        <label>Contraseña</label>
        <input type="password"
               name="password"
               v-model="form.password"
               required
               placeholder="••••••••" />

        <button type="submit" :disabled="loading">
            <span v-if="loading">Verificando...</span>
            <span v-else>Ingresar</span>
        </button>

        <div style="display: flex; justify-content: center; margin-top: 10px;">
            <a href="@Url.Action("Recuperar", "Password")" style="font-size: 0.85em; color: #007bff; text-decoration: none;">¿Olvidó su contraseña?</a>
        </div>
    </form>

        <div class="auth-footer" style="margin-top: 20px; text-align: center; border-top: 1px solid #eee; padding-top: 15px;">
            <p style="font-size: 0.9em; color: #666;">
                ¿No tienes cuenta? <a href="@Url.Action("Registro", "Auth")" style="font-weight: bold; color: #007bff; text-decoration: none;">Regístrate aquí</a>
            </p>
        </div>
    </div>

    <script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>
    <script src="~/Scripts/app/login-app.js"></script>
</body>
</html>