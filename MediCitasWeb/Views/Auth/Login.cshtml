@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Iniciar Sesión - MediCitas</title>
    <link href="~/Content/auth.css" rel="stylesheet" />
</head>
<body class="auth-page">

    <div class="auth-container">
        <h1>MediCitas</h1>
        <p class="subtitle">Acceso al sistema</p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="error-summary" style="color: #e74c3c; text-align: center; margin-bottom: 15px; font-size: 0.9em;">
                @Html.ValidationSummary(true)
            </div>
        }

        <form method="post" action="@Url.Action("Login", "Auth")" id="loginForm">

            <label>Número de documento</label>
            <input type="text"
                   id="numDocLogin"
                   name="numero_documento"
                   required
                   placeholder="Ingrese su identificación"
                   value="@Request["numero_documento"]" />

            <label>Contraseña</label>
            <input type="password"
                   id="passwordLogin"
                   name="password"
                   required
                   placeholder="••••••••" />

            <div class="auth-options" style="display: flex; justify-content: center; margin-top: 10px;">
                <a href="@Url.Action("Recuperar", "Auth")" class="auth-links" style="font-size: 0.85em;">¿Olvidó su contraseña?</a>
            </div>

            <button type="submit" id="btnLogin">Ingresar</button>
        </form>

        <div class="auth-footer" style="margin-top: 20px; text-align: center; border-top: 1px solid #eee; padding-top: 15px;">
            <p style="font-size: 0.9em; color: #666;">
                ¿No tienes cuenta? <a href="@Url.Action("Registro", "Auth")" style="font-weight: bold;">Regístrate aquí</a>
            </p>
        </div>
    </div>

    <script src="~/Scripts/auth-login.js"></script>
</body>
</html>