
@{
    ViewBag.Title = "Asignación de Citas";
    Layout = null; // Si usas una Master Page (Layout), cámbialo a "~/Views/Shared/_Layout.cshtml"
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title</title>

    <link href="@Url.Content("~/Content/bootstrap.min.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Content/user.css")" rel="stylesheet" />
</head>
<body>

    <div class="container mt-3">
        <ul class="nav nav-tabs">
            <li class="nav-item">
                <a class="nav-link active">Asignación de citas</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="@Url.Action("MisCitas", "Pages")">Consulta y cancelación</a>
            </li>
        </ul>
    </div>

    <div class="container mt-3 user-container">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="fw-bold">ASIGNACIÓN DE CITAS</h4>
            <div>
                <a href="@Url.Action("Chat", "ChatBot")" class="btn btn-outline-primary btn-sm me-2">🤖 Asistente</a>
                <a href="@Url.Action("Login", "Pages")" class="btn btn-danger btn-sm">❌ Cerrar sesión</a>
            </div>
        </div>

        <div id="panelAgendamiento" class="card p-4 mb-5" style="display:none;">
            <h5 class="fw-bold mb-3">Agendar Cita</h5>
            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()

                <div class="row mb-3">
                    <div class="col-md-4">
                        <label>Especialidad médica *</label>
                        <select id="especialidad" class="form-control">
                            <option value="">Seleccione</option>
                            <option>Medicina General</option>
                            <option>Cardiología</option>
                        </select>
                    </div>
                </div>

                <button type="button" class="btn btn-success" onclick="confirmarCita()">Confirmar Cita</button>
            }
        </div>
    </div>

    <script>
        function mostrarPanel() {
            document.getElementById("panelAgendamiento").style.display = "block";
        }

        function confirmarCita() {
            const especialidad = document.getElementById("especialidad").value;
            const tipo = document.getElementById("tipoConsulta").value;
            const fecha = document.getElementById("fechaCita").value;
            const hora = document.getElementById("horaCita").value;

            if (!especialidad || !tipo || !fecha || !hora) {
                alert("Debe completar todos los campos obligatorios.");
                return;
            }
            alert("Cita agendada correctamente.");
        }
    </script>
</body>
</html>