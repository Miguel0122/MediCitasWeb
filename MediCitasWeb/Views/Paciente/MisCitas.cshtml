@model List<MediCitasWeb.Models.Cita>
@{
    ViewBag.Title = "Mis Citas Médicas";
    Layout = "~/Views/Shared/_Layout.cshtml"; // <--- Esto hace toda la magia
}

<div class="app-container animate__animated animate__fadeIn">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary">Historial de Citas</h2>
        <a href="@Url.Action("AgendarCita", "Paciente")" class="btn btn-primary shadow-sm">
            <i class="bi bi-plus-lg"></i> Agendar Nueva
        </a>
    </div>

    <div class="table-responsive shadow-sm bg-white p-3 rounded-4">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Especialidad</th>
                    <th>Fecha</th>
                    <th>Hora</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td><span class="badge bg-info text-dark">@c.especialidad</span></td>
                        <td>@c.fecha_cita.ToShortDateString()</td>
                        <td>@c.hora_cita</td>
                        <td>
                            <span class="badge @(c.estado == "Activa" ? "bg-success" : "bg-secondary")">@c.estado</span>
                        </td>
                        <td>
                            @if (c.estado == "Activa")
                            {
                                <button class="btn btn-sm btn-outline-danger">Cancelar</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>