@model List<MediCitasWeb.Models.Cita>
@{
    ViewBag.Title = "Mis Citas Médicas";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <link href="~/Content/bootstrap.min.css" rel="stylesheet" />
    <style>
        .status-activa {
            color: #28a745;
            font-weight: bold;
        }

        .status-cancelada {
            color: #dc3545;
            font-weight: bold;
        }
    </style>
</head>
<body class="bg-light">

    <div class="container mt-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold">Historial de Citas</h2>
            <a href="@Url.Action("AgendarCita", "Pages")" class="btn btn-primary">+ Agendar Nueva</a>
        </div>

        <div class="table-responsive shadow-sm bg-white p-3 rounded">
            <table class="table table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Especialidad</th>
                        <th>Fecha</th>
                        <th>Hora</th>
                        <th>Tipo</th>
                        <th>Estado</th>
                        <th>Acción</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Count > 0)
                    {
                        foreach (var c in Model)
                        {
                            <tr>
                                <td>@c.especialidad</td>
                                <td>@c.fecha_cita.ToShortDateString()</td>
                                <td>@c.hora_cita.ToString(@"hh\:mm")</td>
                                <td>@c.tipo_consulta</td>
                                <td>
                                    <span class="badge @(c.estado == "Activa" ? "bg-success" : "bg-secondary")">
                                        @c.estado
                                    </span>
                                </td>
                                <td>
                                    <button class="btn btn-sm btn-outline-danger">Cancelar</button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">No tienes citas agendadas aún.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</body>
</html>