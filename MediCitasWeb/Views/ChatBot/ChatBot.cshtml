@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>ChatBot MediCitas</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/Content/chatbot.css" rel="stylesheet" />
</head>
<body>
    <div class="chat-container">
        <div class="chat-header d-flex align-items-center">
            <a href="@Url.Action("AgendarCita", "Paciente")" class="btn btn-sm btn-light me-2">← Volver</a>
            <div class="text-center flex-grow-1 text-white">
                <strong>🤖 MediCitas Assistant</strong>
                <div style="font-size:12px; opacity:0.8;">Atención virtual 24/7</div>
            </div>
            <button class="btn btn-sm btn-light" id="btnLimpiar">Limpiar</button>
        </div>

        <div class="chat-messages" id="chatMessages">
            <div class="message bot">
                <div>¡Hola! Soy MediBot. ¿En qué puedo ayudarte hoy?</div>
                <div class="time">@DateTime.Now.ToString("HH:mm")</div>
            </div>
        </div>

        <div id="typingIndicator" class="p-2 ms-3 text-muted small" style="display:none;">
            <span class="spinner-grow spinner-grow-sm"></span> MediBot está escribiendo...
        </div>

        <div class="chat-input d-flex p-3 border-top">
            <input type="text" id="txtEntrada" class="form-control me-2" placeholder="Escribe tu mensaje..." />
            <button class="btn btn-primary" id="btnEnviar">Enviar</button>
        </div>
    </div>

    <script src="~/Scripts/app/chatbot-app.js"></script>
</body>
</html>