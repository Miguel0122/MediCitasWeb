@{
    Layout = null;
    var sesionId = ViewBag.SesionId ?? 0;
    var contexto = Uri.EscapeDataString(ViewBag.ContextoUsuario ?? "");
    var nombre = ViewBag.NombreUsuario ?? "";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>ChatBot MediCitas</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        body {
            background: #f4f7fb;
            font-family: 'Segoe UI', sans-serif;
            margin: 0;
            height: 100vh;
        }

        .chat-container {
            max-width: 900px;
            margin: 20px auto;
            background: white;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.08);
            display: flex;
            flex-direction: column;
            height: calc(100vh - 40px);
        }

        .chat-header {
            background: linear-gradient(135deg, #0d6efd, #4e73df);
            color: white;
            padding: 15px 20px;
            border-radius: 20px 20px 0 0;
        }

        .chat-messages {
            flex: 1;
            padding: 20px;
            overflow-y: auto;
        }

        .message {
            margin-bottom: 15px;
            max-width: 75%;
            padding: 12px 15px;
            border-radius: 15px;
            font-size: 14px;
        }

            .message.user {
                background: #0d6efd;
                color: white;
                margin-left: auto;
                border-bottom-right-radius: 5px;
            }

            .message.bot {
                background: #e9ecef;
                color: #333;
                border-bottom-left-radius: 5px;
            }

        .time {
            font-size: 10px;
            opacity: 0.7;
            margin-top: 5px;
            text-align: right;
        }

        .chat-input {
            display: flex;
            padding: 15px;
            border-top: 1px solid #eee;
        }

            .chat-input input {
                flex: 1;
                border-radius: 30px;
                padding: 10px 15px;
                border: 1px solid #ddd;
            }

            .chat-input button {
                margin-left: 10px;
                border-radius: 30px;
            }

        .typing-indicator {
            padding: 12px 18px;
            background: #e9ecef;
            border-radius: 20px;
            border-bottom-left-radius: 5px;
            display: inline-block;
        }

        .typing-dot {
            display: inline-block;
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #999;
            margin: 0 2px;
            animation: typing 1.4s infinite;
        }

            .typing-dot:nth-child(2) {
                animation-delay: 0.2s;
            }

            .typing-dot:nth-child(3) {
                animation-delay: 0.4s;
            }

        @@keyframes typing {
            0%, 60%, 100% {
                transform: translateY(0);
                opacity: 0.5;
            }

            30% {
                transform: translateY(-10px);
                opacity: 1;
            }
        }

        .pulse-dot {
            width: 8px;
            height: 8px;
            background-color: #28a745;
            border-radius: 50%;
            display: inline-block;
            margin-right: 5px;
            animation: pulse 2s infinite;
        }

        @@keyframes pulse {
            0% {
                box-shadow: 0 0 0 0 rgba(40,167,69,0.7);
            }

            70% {
                box-shadow: 0 0 0 10px rgba(40,167,69,0);
            }

            100% {
                box-shadow: 0 0 0 0 rgba(40,167,69,0);
            }
        }
    </style>
</head>
<body data-sesion-id="@sesionId"
      data-contexto="@contexto"
      data-nombre="@nombre">

    <div class="chat-container">
        <div class="chat-header d-flex align-items-center">
            <a href="@Url.Action("Dashboard", "Home")" class="btn btn-sm btn-light me-2">
                <i class="bi bi-arrow-left"></i>
            </a>
            <div class="text-center flex-grow-1">
                <strong><i class="bi bi-robot"></i> MediBot</strong>
                <div style="font-size:12px; opacity:0.8;">
                    <span class="pulse-dot"></span> Conectado
                </div>
            </div>
            <button class="btn btn-sm btn-light" id="btnLimpiar">
                <i class="bi bi-trash"></i>
            </button>
        </div>

        <div class="chat-messages" id="chatMessages"></div>

        <div id="typingIndicator" class="p-2 ms-3" style="display:none;">
            <div class="typing-indicator">
                <span class="typing-dot"></span>
                <span class="typing-dot"></span>
                <span class="typing-dot"></span>
            </div>
        </div>

        <div class="chat-input d-flex p-3 border-top">
            <input type="text" id="txtEntrada" class="form-control me-2" placeholder="Escribe tu mensaje..." />
            <button class="btn btn-primary" id="btnEnviar">
                <i class="bi bi-send"></i> Enviar
            </button>
        </div>
    </div>

    <script src="~/Scripts/app/chatbot-app.js"></script>
</body>
</html>
