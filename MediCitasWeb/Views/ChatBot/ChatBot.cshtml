@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>ChatBot MediCitas</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/Content/chatbot.css" rel="stylesheet" />
</head>

<body>

    <div id="chatApp" class="chat-container">

        <div class="chat-header">

            <a href="@Url.Action("AgendarCita", "Pages")"
               class="btn btn-sm btn-light me-2">
                ← Volver
            </a>

            <div class="text-center flex-grow-1">
                🤖 MediCitas Assistant
                <div style="font-size:12px; opacity:0.8;">
                    Atención virtual 24/7
                </div>
            </div>

            <button class="btn btn-sm btn-light"
                    @@click="limpiarChat"
                    :disabled="loading">
                Limpiar
            </button>

        </div>


        <div class="chat-messages">

            <div v-for="(msg, index) in mensajes"
                 :key="index"
                 class="message"
                 :class="msg.tipo">

                <div v-html="msg.texto"></div>

                <div class="time">
                    {{ msg.hora }}
                </div>

            </div>


            <div v-if="loading" class="message bot">
                <span class="typing">Escribiendo...</span>
            </div>

        </div>


        <div class="chat-input">

            <input type="text"
                   v-model="entrada"
                   placeholder="Escribe tu mensaje..."
                   @@keyup.enter="enviarMensaje"
                   :disabled="loading" />

            <button class="btn btn-primary"
                    @@click="enviarMensaje"
                    :disabled="loading || entrada.trim() === ''">
                Enviar
            </button>

        </div>

    </div>


    <script src="https://cdn.jsdelivr.net/npm/vue@2/dist/vue.js"></script>
    <script src="~/Scripts/app/chatbot-app.js"></script>

</body>
</html>