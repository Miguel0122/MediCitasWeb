@model MediCitasWeb.Models.CrearDoctorViewModel
@{
    Layout = null;
    ViewBag.Title = "Crear Doctor";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Crear Doctor - MediCitas</title>

    <link href="~/Content/bootstrap.min.css" rel="stylesheet" />
</head>

<body class="admin-page">

    <div id="crearDoctorApp">

        <div class="container mt-5" style="max-width:600px;">
            <div class="card p-4">

                <h3 class="text-primary mb-4">Registrar nuevo Doctor</h3>

                @Html.ValidationSummary(false, "", new { @class = "text-danger" })

                @if (TempData["Exito"] != null)
                {
                    <div class="alert alert-success">@TempData["Exito"]</div>
                }

                <!-- FORM MVC NORMAL -->
                <form method="post"
                      action="@Url.Action("CrearDoctor", "Admin")"
                      @@submit="handleSubmit">

                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label">Nombres</label>
                        <input type="text"
                               name="nombres"
                               class="form-control"
                               v-model="form.nombres"
                               required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Apellidos</label>
                        <input type="text"
                               name="apellidos"
                               class="form-control"
                               v-model="form.apellidos"
                               required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Número de documento</label>
                        <input type="text"
                               name="numero_documento"
                               class="form-control"
                               v-model="form.documento"
                               @@input="soloNumeros"
                               required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Correo</label>
                        <input type="email"
                               name="correo"
                               class="form-control"
                               v-model="form.correo"
                               required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Contraseña</label>
                        <input type="password"
                               name="password"
                               class="form-control"
                               v-model="form.password"
                               required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Especialidad</label>
                        <select name="especialidad"
                                class="form-select"
                                v-model="form.especialidad"
                                required>

                            <option value="">Seleccione...</option>
                            <option>Medicina General</option>
                            <option>Pediatría</option>
                            <option>Cardiología</option>
                            <option>Odontología</option>

                        </select>
                    </div>

                    <div class="d-flex gap-2 mt-4">

                        <button type="submit"
                                class="btn btn-success"
                                :disabled="loading">

                            <span v-if="loading">Creando...</span>
                            <span v-else>Crear Doctor</span>

                        </button>

                        <a href="@Url.Action("PanelAdmin", "Admin")"
                           class="btn btn-secondary">
                            Volver
                        </a>

                    </div>

                </form>

                <!-- MENSAJE VUE -->
                <div class="text-danger mt-3 text-center" v-if="mensaje">
                    {{ mensaje }}
                </div>

            </div>
        </div>

    </div>

    <script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>
    <script src="~/Scripts/app/admin-register-app.js"></script>

</body>
</html>