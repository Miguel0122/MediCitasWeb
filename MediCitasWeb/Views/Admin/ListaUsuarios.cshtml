@model List<MediCitasWeb.Models.Usuario>
@{
    Layout = null;
    ViewBag.Title = "Usuarios - Panel Administrativo";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Usuarios - MediCitas</title>
    <link href="~/Content/admin.css" rel="stylesheet" />
    <link href="~/Content/bootstrap.min.css" rel="stylesheet" />
</head>
<body class="admin-page">

    <header class="admin-header">
        <h1>MediCitas | Usuarios</h1>
        <div style="display:flex; gap:10px; align-items:center;">
            <a href="@Url.Action("PanelAdmin","Admin")" class="btn-secondary">Volver al panel</a>
            <a href="@Url.Action("Logout","Admin")" class="btn-logout">Cerrar sesi¾n</a>
        </div>
    </header>

    <div class="admin-container">

        <h2 class="section-title">Listado de usuarios</h2>

        <div class="report-buttons" style="margin-bottom:15px;">
            <a href="@Url.Action("CrearDoctor","Admin")" class="btn-primary">+ Crear Doctor</a>
        </div>

        <table class="table">
            <thead>
                <tr>
                    <th>Documento</th>
                    <th>Nombre</th>
                    <th>Correo</th>
                    <th>Rol</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model)
                {
                    <tr>
                        <td>@u.numero_documento</td>
                        <td>@u.nombres_usuario @u.apellidos_usuario</td>
                        <td>@u.correo_usuario</td>
                        <td>@u.rol_usuario</td>
                    </tr>
                }
            </tbody>
        </table>

    </div>
</body>
</html>
