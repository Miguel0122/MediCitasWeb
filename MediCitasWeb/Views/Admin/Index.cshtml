@{
    Layout = null;
    ViewBag.Title = "Panel Administrativo - MediCitas";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Panel Admin - MediCitas</title>
    <link href="~/Content/admin.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

<body class="admin-page">

    <!-- HEADER -->
    <header class="admin-header">
        <h1>MediCitas | Panel Administrativo</h1>
        <a href="/Admin/Logout" class="btn-logout">Cerrar sesión</a>
    </header>

    <!-- CONTENIDO -->
    <div class="admin-container">

        <h2 class="section-title">Gestión de Citas</h2>

        <!-- TARJETAS -->
        <div class="stats-grid">
            <div class="stat-card">
                <h3>Total de Citas</h3>
                <p>@ViewBag.TotalCitas</p>
            </div>

            <div class="stat-card">
                <h3>Citas Pendientes</h3>
                <p>@ViewBag.CitasPendientes</p>
            </div>

            <div class="stat-card">
                <h3>Citas Completadas</h3>
                <p>@ViewBag.CitasCompletadas</p>
            </div>

            <!-- NUEVA -->
            <div class="stat-card">
                <h3>Citas Canceladas</h3>
                <p>@ViewBag.CitasCanceladas</p>
            </div>

            <!-- NUEVA -->
            <div class="stat-card">
                <h3>Pacientes Registrados</h3>
                <p>@ViewBag.TotalPacientes</p>
            </div>
        </div>

        <!-- FILTROS -->
        <form method="get">

            <div class="search-box">
                <input type="text" name="documento" placeholder="Buscar por documento" />

                <!-- Filtro por Estado -->
                <select name="estado">
                    <option value="">Todos los estados</option>
                    <option value="Pendiente">Pendientes</option>
                    <option value="Completada">Completadas</option>
                    <option value="Cancelada">Canceladas</option>
                </select>

                <!-- Filtro por Fecha -->
                <input type="date" name="fechaInicio" />
                <input type="date" name="fechaFin" />

                <button type="submit" class="btn-primary">Filtrar</button>
                <a href="/Admin/Index" class="btn-secondary">Mostrar todos</a>
            </div>

        </form>

        <!-- GRÁFICA -->
        <div class="card-large">
            <h3>Resumen de Citas</h3>
            <canvas id="graficaCitas" height="100"></canvas>
        </div>

        <!-- TABLA -->
        <div class="card-large">
            <table class="table">
                <thead>
                    <tr>
                        <th>Documento</th>
                        <th>Nombre</th>
                        <th>Correo</th>
                        <th>Rol</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>123456</td>
                        <td>Miguel Ángel Mercado</td>
                        <td>miguel@gmail.com</td>
                        <td>Administrador</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <!-- REPORTES -->
        <div class="report-buttons">
            <a href="#" class="btn-primary">Ver reporte de citas</a>
            <a href="#" class="btn-primary">Ver reporte de usuarios</a>
        </div>

    </div>

    <!-- SCRIPT GRÁFICA -->
    <script>
        var ctx = document.getElementById('graficaCitas').getContext('2d');

        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: ['Pendientes', 'Completadas', 'Canceladas'],
                datasets: [{
                    label: 'Cantidad de Citas',
                    data: [
                        @ViewBag.CitasPendientes ?? 0,
                        @ViewBag.CitasCompletadas ?? 0,
                        @ViewBag.CitasCanceladas ?? 0
                    ]
                }]
            }
        });
    </script>

</body>
</html>