@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bienvenidos a MediCitas</title>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <link href="~/Content/welcome-style.css" rel="stylesheet" />
</head>
<body>

    <div id="app">
        <nav class="navbar navbar-expand-lg navbar-light bg-white sticky-top shadow-sm">
            <div class="container">
                <a class="navbar-brand fw-bold text-primary" href="#">
                    <i class="bi bi-heart-pulse-fill"></i> MEDICITAS
                </a>
                <div class="d-flex">
                    <a href="@Url.Action("Login", "Auth")" class="btn btn-outline-primary me-2">Iniciar Sesión</a>
                    <a href="@Url.Action("Registro", "Auth")" class="btn btn-primary">Registrarse</a>
                </div>
            </div>
        </nav>

        <header class="hero-section">
            <div class="container py-5 text-center text-md-start">
                <div class="row align-items-center">
                    <div class="col-md-6">
                        <h1 class="display-3 fw-bold mb-4">{{ mensajeBienvenida }}</h1>

                        <p class="lead mb-4 opacity-90">
                            Gestiona tus citas médicas, consulta especialistas y lleva el control de tu atención en salud desde una sola plataforma.
                        </p>

                        <p class="small opacity-75 mb-5">
                            MediCitas conecta pacientes y profesionales de la salud de forma rápida, segura y organizada.
                        </p>
                        <a href="@Url.Action("Registro", "Auth")" class="btn btn-light btn-lg px-5 py-3 fw-bold text-primary shadow-lg">¡Empezar Ahora!</a>
                    </div>
                    <div class="col-md-6 d-none d-md-block">
                        <img src="https://img.freepik.com/free-vector/doctors-concept-illustration_114360-1515.jpg" alt="Salud" class="img-fluid rounded-4 shadow-2xl">
                    </div>
                </div>
            </div>
        </header>

        <section class="container my-5 py-5">
            <div class="text-center mb-5">
                <h2 class="fw-bold">¿Cómo funciona?</h2>
                <p class="text-muted">Tu cita médica en 3 simples pasos</p>
            </div>
            <div class="row g-4 text-center">
                <div class="col-md-4">
                    <div class="p-3">
                        <div class="step-number mx-auto">1</div>
                        <h5 class="fw-bold">Regístrate</h5>
                        <p class="small text-muted">Crea tu cuenta con tus datos básicos de salud.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-3">
                        <div class="step-number mx-auto">2</div>
                        <h5 class="fw-bold">Elige tu médico</h5>
                        <p class="small text-muted">Busca por especialidad y consulta la disponibilidad.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-3">
                        <div class="step-number mx-auto">3</div>
                        <h5 class="fw-bold">¡Listo!</h5>
                        <p class="small text-muted">Recibe confirmación instantánea en tu correo.</p>
                    </div>
                </div>
            </div>
        </section>


        <section class="container my-5 py-5">
            <div class="text-center mb-5">
                <h2 class="fw-bold">Beneficios para Pacientes</h2>
                <p class="text-muted">Control total de tu atención médica</p>
            </div>

            <div class="row g-4">

                <div class="col-md-3 text-center">
                    <i class="bi bi-calendar-check display-5 text-primary"></i>
                    <h6 class="fw-bold mt-3">Agendamiento rápido</h6>
                    <p class="small text-muted">
                        Programa tus citas médicas en minutos sin filas ni llamadas.
                    </p>
                </div>

                <div class="col-md-3 text-center">
                    <i class="bi bi-person-vcard display-5 text-primary"></i>
                    <h6 class="fw-bold mt-3">Historial médico</h6>
                    <p class="small text-muted">
                        Consulta el registro de tus citas y atenciones médicas.
                    </p>
                </div>

                <div class="col-md-3 text-center">
                    <i class="bi bi-hospital display-5 text-primary"></i>
                    <h6 class="fw-bold mt-3">Especialistas disponibles</h6>
                    <p class="small text-muted">
                        Encuentra médicos por especialidad y disponibilidad.
                    </p>
                </div>

                <div class="col-md-3 text-center">
                    <i class="bi bi-shield-check display-5 text-primary"></i>
                    <h6 class="fw-bold mt-3">Datos seguros</h6>
                    <p class="small text-muted">
                        Tu información médica está protegida y encriptada.
                    </p>
                </div>

            </div>
        </section>

        <section class="bg-light py-5">
            <div class="container my-5">

                <div class="row align-items-center">

                    <div class="col-md-6">
                        <h2 class="fw-bold">También pensado para profesionales de la salud</h2>

                        <p class="text-muted">
                            MediCitas permite a médicos y especialistas gestionar sus consultas,
                            organizar su agenda y visualizar las citas programadas de forma clara y eficiente.
                        </p>

                        <ul class="small text-muted">
                            <li>✔ Gestión de agenda médica</li>
                            <li>✔ Visualización de citas por especialidad</li>
                            <li>✔ Historial de pacientes</li>
                            <li>✔ Organización eficiente del tiempo</li>
                        </ul>

                    </div>

                    <div class="col-md-6 text-center">
                        <i class="bi bi-heart-pulse display-1 text-primary"></i>
                    </div>

                </div>

            </div>
        </section>

        <section class="bg-light py-5">
            <div class="container my-5">
                <div class="text-center mb-5">
                    <h2 class="fw-bold">Nuestros Servicios</h2>
                    <p class="text-muted">Innovación al servicio de tu bienestar</p>
                </div>
                <div class="row g-4">
                    <div class="col-md-4" v-for="servicio in servicios" :key="servicio.titulo">
                        <div class="card h-100 p-4 feature-card text-center">
                            <div class="display-5 text-primary mb-3">
                                <i :class="'bi ' + servicio.icono"></i>
                            </div>
                            <h5 class="fw-bold">{{ servicio.titulo }}</h5>
                            <p class="text-muted small">{{ servicio.descripcion }}</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <footer class="bg-dark text-light pt-5 pb-4">

            <div class="container">

                <div class="row">

                    <div class="col-md-4 mb-4">

                        <h5 class="fw-bold text-info">
                            <i class="bi bi-heart-pulse"></i> MediCitas
                        </h5>

                        <p class="small text-light opacity-75">
                            Plataforma digital para la gestión de citas médicas que conecta
                            pacientes con profesionales de la salud de manera rápida,
                            segura y organizada.
                        </p>

                    </div>

                    <div class="col-md-2 mb-4">

                        <h6 class="fw-bold">Plataforma</h6>

                        <ul class="list-unstyled small">

                            <li><a href="#" class="text-decoration-none text-light opacity-75">Inicio</a></li>

                            <li><a href="#" class="text-decoration-none text-light opacity-75">Servicios</a></li>

                            <li><a href="#" class="text-decoration-none text-light opacity-75">Especialidades</a></li>

                            <li><a href="#" class="text-decoration-none text-light opacity-75">Contacto</a></li>

                        </ul>

                    </div>

                    <div class="col-md-3 mb-4">

                        <h6 class="fw-bold">Servicios Médicos</h6>

                        <ul class="list-unstyled small">

                            <li>Medicina General</li>
                            <li>Pediatría</li>
                            <li>Cardiología</li>
                            <li>Dermatología</li>
                            <li>Odontología</li>

                        </ul>

                    </div>

                    <div class="col-md-3 mb-4">

                        <h6 class="fw-bold">Contacto</h6>

                        <p class="small opacity-75 mb-1">
                            <i class="bi bi-envelope"></i> soporte@medicitas.com
                        </p>

                        <p class="small opacity-75 mb-1">
                            <i class="bi bi-telephone"></i> +57 300 000 0000
                        </p>

                        <p class="small opacity-75">
                            <i class="bi bi-geo-alt"></i> Cartagena, Colombia
                        </p>

                        <div class="mt-3">

                            <a href="#" class="text-light me-3"><i class="bi bi-facebook"></i></a>
                            <a href="#" class="text-light me-3"><i class="bi bi-instagram"></i></a>
                            <a href="#" class="text-light"><i class="bi bi-twitter"></i></a>

                        </div>

                    </div>

                </div>

                <hr class="border-light opacity-25">

                <div class="text-center small opacity-75">

                    © 2026 MediCitas — Todos los derechos reservados.

                </div>

            </div>

        </footer>
    </div>

    <script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>
    <script src="~/Scripts/app/welcome-app.js"></script>

</body>
</html>